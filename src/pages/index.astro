---
import * as Lucide from "lucide-react";
import HeroCopyEmailButton from "@/components/HeroCopyEmailButton";
import LogoMarquee from "@/components/LogoMarquee";
import WorkSection from "@/components/WorkSection";
import "@/styles/global.css";

const { ArrowUpRight } = Lucide;

const logos = [
  {
    alt: "The Economist",
    displayWidth: "9.2rem",
    height: 32,
    src: "/assets/logo-economist.svg",
    width: 277,
  },
  {
    alt: "Prada",
    displayWidth: "5.7rem",
    height: 354,
    src: "/assets/logo-prada.svg",
    width: 2279,
  },
  {
    alt: "British Vogue",
    displayWidth: "4.8rem",
    height: 410,
    src: "/assets/logo-vogue.svg",
    width: 1544,
  },
  {
    alt: "Ferrari",
    displayWidth: "6.15rem",
    height: 21,
    src: "/assets/logo-ferrari.svg",
    width: 94,
  },
  {
    alt: "Dazed Media",
    displayWidth: "5.4rem",
    height: 175,
    src: "/assets/logo-dazed.svg",
    width: 727,
  },
  {
    alt: "Hitachi",
    displayWidth: "7.4rem",
    height: 32,
    src: "/assets/logo-hitachi.svg",
    width: 207,
  },
  {
    alt: "Google",
    displayWidth: "6.2rem",
    height: 300,
    src: "/assets/logo-google.svg",
    width: 948,
  },
  {
    alt: "LVMH",
    displayWidth: "6.4rem",
    height: 681,
    src: "/assets/logo-lvmh.svg",
    width: 2336,
  },
  {
    alt: "L’Oréal",
    displayWidth: "6.5rem",
    height: 145,
    src: "/assets/logo-loreal.svg",
    width: 800,
  },
  {
    alt: "Barclays",
    displayWidth: "6.8rem",
    height: 66,
    src: "/assets/logo-barclays.svg",
    width: 391,
  },
];

const rawHeroTitleLines = [
  [
    { text: "Thinking" },
    { text: "outside" },
    { text: "the model", highlight: true },
  ],
];

let heroWordIndex = 0;
const heroTitleLines = rawHeroTitleLines.map((line) =>
  line.map((word) => ({
    ...word,
    delay: `${180 + heroWordIndex++ * 64}ms`,
  })),
);

const heroTitleText = "Thinking outside the model";

const judgementParts = [
  {
    emphasised: false,
    text: "AI can make every business smarter — and more alike. Advantage lies in what the pattern leaves out: human contradiction, cultural change, and the nerve",
  },
  {
    emphasised: true,
    text: "to build what has no precedent.",
  },
];

const judgementWords = judgementParts.flatMap((part) =>
  part.text.split(" ").map((word) => ({
    emphasised: Boolean(part.emphasised),
    text: word,
  })),
);

const judgementText = judgementParts.map((part) => part.text).join(" ");
const judgementLastIndex = judgementWords.length - 1;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta
      name="description"
      content="Adriana Coppola is a creative business strategist building real-world strategy for founders, CEOs and C-suites."
    />
    <title>Adriana Coppola</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link
      rel="preload"
      href="/fonts/Mori/PPMori-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="preload" href="/assets/adriana-portrait.png" as="image" />
  </head>
  <body>
    <div class="site-grid" aria-hidden="true"></div>
    <header class="site-header" data-site-header data-scrolled="false">
      <a class="brand-link" href="#top" aria-label="Adriana Coppola home">
        Adriana Coppola
      </a>
      <nav class="site-nav" aria-label="Primary">
        <a href="#approach">Approach</a>
        <a href="#work">Work</a>
        <a href="#contact">Contact</a>
      </nav>
    </header>

    <main id="top">
      <section class="hero-section" aria-labelledby="hero-title">
        <div class="hero-copy">
          <p class="section-label hero-eyebrow">PRODUCT, COMMERCIAL &amp; GROWTH STRATEGY</p>
          <h1 id="hero-title" aria-label={heroTitleText}>
            {heroTitleLines.map((line, lineIndex) => (
              <span
                class:list={[
                  "hero-title-line",
                  lineIndex === 1 && "hero-title-secondary",
                ]}
                aria-hidden="true"
              >
                {line.map((word, wordIndex) => (
                  <>
                    <span class="hero-title-word" style={`--reveal-delay: ${word.delay}`}>
                      {word.highlight ? (
                        <span class="gradient-wave-text" data-wave-text={word.text}>
                          {word.text}
                        </span>
                      ) : (
                        word.text
                      )}
                    </span>
                    {wordIndex < line.length - 1 && " "}
                  </>
                ))}
              </span>
            ))}
          </h1>
          <p class="hero-intro">
            I convert blind spots into breakthroughs, new products, and revenue streams.
          </p>
          <div class="hero-actions">
            <HeroCopyEmailButton client:load />
          </div>
          <div class="client-strip" aria-label="Selected clients">
            <p>Selected clients</p>
            <LogoMarquee logos={logos} client:load />
          </div>
        </div>
        <figure class="hero-media">
          <img
            src="/assets/adriana-portrait.png"
            alt="Black-and-white portrait of Adriana Coppola"
            width="646"
            height="451"
          />
        </figure>
      </section>

      <section id="approach" class="approach-section" aria-labelledby="approach-title">
        <p class="section-label" data-reveal style="--reveal-delay: 0ms">APPROACH</p>
        <h2 id="approach-title" data-reveal style="--reveal-delay: 80ms">
          Creative leaps.{" "}
          <span class="gradient-wave-text" data-wave-text="Commercial landings.">
            Commercial landings.
          </span>
        </h2>
        <div class="approach-intro" data-reveal style="--reveal-delay: 150ms">
          <p>
            AI and benchmarking are good at optimising the known. I work on what does not yet
            exist.
          </p>
          <p>
            I go into the real world—subcultures, microcommunities and the cultural margins—to
            find missed opportunities.
          </p>
          <p>
            I pitch the thinking, build the prototype and get it into market: a new product,
            revenue stream or business model. I measure, optimise and have a proven track
            record for ROI.
          </p>
        </div>

        <div class="principles">
          <article data-reveal style="--reveal-delay: 230ms">
            <p>
              <span>01 — Cultural periphery</span>
              I look to real behaviour, micro-communities and pioneers beyond the category—where
              the mainstream is made before it is named.
            </p>
          </article>
          <article data-reveal style="--reveal-delay: 300ms">
            <p>
              <span>02 — Category collision</span>
              I bring together ideas, behaviours and industries that rarely meet. That is
              where the leap happens—and new value appears.
            </p>
          </article>
          <article data-reveal style="--reveal-delay: 370ms">
            <p>
              <span>03 — Commercial reality</span>
              I pitch the idea, build the prototype and take it to market. The work is measured
              in adoption, uplift and revenue.
            </p>
          </article>
        </div>
      </section>

      <section class="judgement-section" data-judgement aria-label="Judgement">
        <div class="judgement-sticky">
          <p aria-label={judgementText}>
            <span class="judgement-words" aria-hidden="true">
              {judgementWords.map((word, index) => {
                const wordStart = judgementLastIndex > 0
                  ? (index / judgementLastIndex) * 0.76
                  : 0;
                const wordStartValue = wordStart.toFixed(3);

                return (
                  <span
                    class="judgement-word"
                    data-judgement-word
                    data-judgement-emphasis={word.emphasised ? "true" : "false"}
                    data-last={index === judgementLastIndex ? "true" : "false"}
                    data-word-start={wordStartValue}
                    style={`--word-start: ${wordStartValue}`}
                  >
                    {word.emphasised ? <em>{word.text}</em> : word.text}
                  </span>
                );
              })}
            </span>
          </p>
        </div>
      </section>

      <section id="work" class="work-section" aria-labelledby="work-title">
        <div class="work-heading">
          <p class="section-label" data-reveal style="--reveal-delay: 0ms">WORK</p>
          <h2 id="work-title" data-reveal style="--reveal-delay: 80ms">
            Built from the{" "}
            <span class="gradient-wave-text" data-wave-text="blind spot.">
              blind spot.
            </span>
          </h2>
          <p class="work-intro" data-reveal style="--reveal-delay: 150ms">
            From subscription growth to enterprise AI, culture-led products and new markets.
            Built, adopted and still creating value—not recommendations left in a deck.
          </p>
        </div>
        <WorkSection client:load />
      </section>
    </main>

    <footer id="contact" class="site-footer" aria-labelledby="contact-title">
      <div class="footer-primary">
        <p id="contact-title" class="section-label" data-reveal style="--reveal-delay: 0ms">
          CONTACT
        </p>
        <div class="footer-links">
          <a
            href="https://www.linkedin.com/in/adrianacoppola/"
            target="_blank"
            rel="noreferrer"
            data-reveal
            style="--reveal-delay: 90ms"
          >
            <img
              class="footer-link-icon"
              src="/assets/icon-linkedin.svg"
              alt=""
              width="32"
              height="32"
              aria-hidden="true"
            />
            LinkedIn
            <ArrowUpRight aria-hidden="true" size={14} strokeWidth={2.2} />
          </a>
          <a href="mailto:adriana.c.coppola@gmail.com" data-reveal style="--reveal-delay: 160ms">
            <img
              class="footer-link-icon"
              src="/assets/icon-at-sign.svg"
              alt=""
              width="12"
              height="12"
              aria-hidden="true"
            />
            Email
            <ArrowUpRight aria-hidden="true" size={14} strokeWidth={2.2} />
          </a>
        </div>
      </div>
      <div class="footer-microgrid" aria-label="Footer details">
        <section data-reveal style="--reveal-delay: 220ms">
          <p class="footer-kicker">Availability</p>
          <p>Open for selected advisory and strategy projects.</p>
        </section>
        <section data-reveal style="--reveal-delay: 280ms">
          <p class="footer-kicker">Best fit</p>
          <p>Founders, CEOs and teams making high-stakes commercial decisions.</p>
        </section>
        <nav aria-label="Footer" data-reveal style="--reveal-delay: 340ms">
          <p class="footer-kicker">Explore</p>
          <a href="#work">Selected work</a>
          <a href="#approach">Approach</a>
          <a href="#top">Back to top</a>
        </nav>
      </div>
      <p class="footer-wordmark" aria-hidden="true">Adriana Coppola</p>
    </footer>

    <script is:inline>
      (() => {
        const header = document.querySelector("[data-site-header]");
        if (!header) return;

        const syncHeader = () => {
          header.setAttribute("data-scrolled", String(window.scrollY > 12));
        };

        syncHeader();
        window.addEventListener("scroll", syncHeader, { passive: true });
      })();

      (() => {
        const section = document.querySelector("[data-judgement]");
        if (!section) return;

        const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
        let ticking = false;
        section.setAttribute("data-enhanced", "true");

        const update = () => {
          const rect = section.getBoundingClientRect();
          const travel = Math.max(1, section.offsetHeight - window.innerHeight);
          const revealLead = window.innerHeight * 0.34;
          const progress = reducedMotion.matches
            ? 1
            : Math.min(1, Math.max(0, (revealLead - rect.top) / (travel + revealLead)));

          section.style.setProperty("--judgement-progress", progress.toFixed(3));

          ticking = false;
        };

        const requestUpdate = () => {
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(update);
        };

        update();
        window.addEventListener("scroll", requestUpdate, { passive: true });
        window.addEventListener("resize", requestUpdate);
        reducedMotion.addEventListener("change", requestUpdate);
      })();

      (() => {
        const revealItems = Array.from(document.querySelectorAll("[data-reveal]"));
        if (!revealItems.length) return;

        document.documentElement.setAttribute("data-reveal-ready", "true");

        const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
        const revealStartedAt = window.performance.now();
        // Hero's last entrance ends around 1420ms; this leaves a short handoff gap.
        const heroApproachDelay = 1500;
        const shouldSequenceAfterHero = !window.location.hash;
        const approachRevealQueue = new Set();
        let approachRevealTimer = null;

        const setRevealed = (item) => {
          item.setAttribute("data-revealed", "true");
        };

        const flushApproachRevealQueue = () => {
          approachRevealQueue.forEach(setRevealed);
          approachRevealQueue.clear();
          approachRevealTimer = null;
        };

        const reveal = (item) => {
          if (shouldSequenceAfterHero && !reducedMotion.matches && item.closest("#approach")) {
            const remainingDelay = heroApproachDelay - (window.performance.now() - revealStartedAt);

            if (remainingDelay > 40) {
              approachRevealQueue.add(item);
              window.clearTimeout(approachRevealTimer);
              approachRevealTimer = window.setTimeout(
                flushApproachRevealQueue,
                Math.round(remainingDelay),
              );
              return;
            }
          }

          setRevealed(item);
        };
        const revealAll = () => revealItems.forEach(reveal);

        if (reducedMotion.matches || !("IntersectionObserver" in window)) {
          revealAll();
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              reveal(entry.target);
              observer.unobserve(entry.target);
            });
          },
          {
            rootMargin: "0px 0px -14% 0px",
            threshold: 0.14,
          },
        );

        const initialRevealItems = [];

        revealItems.forEach((item) => {
          const rect = item.getBoundingClientRect();
          const isVisibleApproachItem =
            shouldSequenceAfterHero &&
            item.closest("#approach") &&
            rect.top < window.innerHeight &&
            rect.bottom > 0;

          if (isVisibleApproachItem) {
            initialRevealItems.push(item);
            return;
          }

          observer.observe(item);
        });

        if (initialRevealItems.length) {
          window.requestAnimationFrame(() => {
            window.requestAnimationFrame(() => {
              initialRevealItems.forEach(reveal);
            });
          });
        }

        reducedMotion.addEventListener("change", (event) => {
          if (!event.matches) return;
          window.clearTimeout(approachRevealTimer);
          approachRevealQueue.clear();
          revealAll();
          observer.disconnect();
        });
      })();
    </script>
  </body>
</html>
